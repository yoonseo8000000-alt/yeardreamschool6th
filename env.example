# ──────────────────────────────────────────────────────────────
# 환경변수 템플릿
# 이 파일을 복사하여 .env 를 만들고 실제 값을 채워주세요.
#   cp .env.example .env
# .env 는 절대 Git에 커밋하지 마세요!
# ──────────────────────────────────────────────────────────────

# 실행 환경 (development | staging | production)
ENV=development

# 데이터베이스 (필요 시)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=myuser
# DB_PASSWORD=secret

# 외부 API 키 (필요 시)
# OPENAI_API_KEY=sk-...
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# 경로 설정
DATA_DIR=data/raw
OUTPUT_DIR=reports/figures
